# VisionChess — environment template
# Copy to .env and adjust values for local development.

# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database (optional — Docker Compose) ───────────
DATABASE_URL=postgresql+asyncpg://visionchess:visionchess@localhost:5432/visionchess

# ── Redis (optional) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ── Storage ──────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# ── API server ───────────────────────────────────────
# Python vision API (apps/api)
API_HOST=127.0.0.1
API_PORT=8001

# ── ML inference ─────────────────────────────────────
INFERENCE_DEVICE=cpu
# Download models first — see ml/models/README.md
MODEL_YOLO=ml/models/pretrained/yolov8_chess_pieces.onnx
MODEL_OCCUPANCY=ml/models/occupancy/occupancy.onnx
MODEL_PIECE=ml/models/piece_classifier/piece_classifier.onnx

# ── Web (Next.js — apps/web) ─────────────────────────
# Proxy /api/v1 → API backend
NEXT_PUBLIC_API_URL=/api/v1
API_BACKEND_URL=http://127.0.0.1:8001
# NEXT_PUBLIC_DEV_MODE=true

# ── Mobile (Vite — apps/mobile) ────────────────────
# Leave empty for 100% offline mobile app
# VITE_API_URL=http://10.0.2.2:8001/api/v1
# VITE_DEV_MODE=true
